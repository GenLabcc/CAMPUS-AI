# Environment variables template for Campus AI
# Copy this file to .env or .env.docker and fill in the values

# Frontend API URL (Must be http://localhost:8000 for local browser access)
VITE_API_URL=http://localhost:8000

# Backend Configuration (Used by Backend service)
# DATABASE_URL=mysql+pymysql://root:password@mysql:3306/campus_ai
# MONGODB_URL=mongodb://mongodb:27017/
# MONGODB_DB=campus_ai_chat
# JWT_SECRET=your_secret_here
# GROQ_API_KEY=your_groq_key_here
